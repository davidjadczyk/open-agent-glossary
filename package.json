{
  "name": "open-agent-glossary",
  "version": "0.1.7",
  "description": "Tool-agnostic glossary management for coding agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "open-agent-glossary": "./bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsup src/adapters/pi/index.ts --format esm --outDir src/adapters/pi/dist --no-splitting --target node20 --external @some-scope/pi-coding-agent",
    "dev": "tsup --watch",
    "dev:ui": "npm --prefix ui run dev",
    "build:ui": "npm --prefix ui run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "glossary",
    "agent",
    "mcp",
    "coding-agent",
    "context-injection",
    "pi-package"
  ],
  "license": "MIT",
  "workspaces": [
    "ui"
  ],
  "files": [
    "dist",
    "bin",
    "README.md",
    "src/adapters/pi/dist",
    "skills"
  ],
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "hono": "^4.12.23",
    "open-agent-glossary": "^0.1.2"
  },
  "optionalDependencies": {
    "open-agent-glossary-ui": "^0.1.2"
  },
  "pi": {
    "extensions": [
      "./src/adapters/pi/dist/index.js"
    ],
    "skills": [
      "./skills"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
